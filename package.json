{
  "name": "xrpl-stablecoin-service",
  "version": "0.1.0",
  "description": "XRPL stablecoin issuance platform - REST API backend on Google Cloud Run",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc && tsc-alias",
    "start": "node dist/${SERVICE:-token}/index.js",
    "start:token": "node dist/token/index.js",
    "start:bank": "node dist/bank/index.js",
    "dev:token": "tsx watch src/token/index.ts",
    "dev:bank": "tsx watch src/bank/index.ts",
    "check": "tsc --noEmit && biome check",
    "fix": "biome check --write --unsafe",
    "test": "jest --verbose",
    "test:integration": "XRPL_NETWORK=devnet SIGNING_PROVIDER=sm jest --config jest.integration.config.ts --verbose --runInBand"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@google-cloud/kms": "^5.4.0",
    "@google-cloud/pubsub": "^5.3.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsqr": "^1.4.0",
    "multer": "^2.1.0",
    "pdf-to-img": "^5.0.0",
    "pngjs": "^7.0.0",
    "ripple-keypairs": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@jest/globals": "^30.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.2",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bip39": "^3.1.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.0.0-dev.1005+sha512.91f84a392eea348ea4852a182912d2520273a4336f933b78cc44bc931eb999923c097e9433a9b355adc1f725725ea99082fc9f032a559df832632e764c92c798"
}
