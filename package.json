{
  "name": "xrpl-stablecoin-service",
  "version": "0.1.0",
  "description": "XRPL stablecoin issuance platform - REST API backend on Google Cloud Run",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc && tsc-alias",
    "start": "node dist/${SERVICE:-token}/index.js",
    "start:token": "node dist/token/index.js",
    "start:bank": "node dist/bank/index.js",
    "dev:token": "tsx watch src/token/index.ts",
    "dev:bank": "tsx watch src/bank/index.ts",
    "check": "tsc --noEmit && biome check",
    "fix": "biome check --write --unsafe",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "XRPL_NETWORK=devnet SIGNING_PROVIDER=sm vitest run --config vitest.integration.config.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@google-cloud/kms": "^5.4.0",
    "@google-cloud/pubsub": "^5.3.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsqr": "^1.4.0",
    "multer": "^2.1.0",
    "pdf-to-img": "^5.0.0",
    "pngjs": "^7.0.0",
    "ripple-keypairs": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bip39": "^3.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
