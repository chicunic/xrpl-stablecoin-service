{
  "name": "xrpl-stablecoin-service",
  "version": "0.1.0",
  "description": "XRPL stablecoin issuance platform - REST API backend on Google Cloud Run",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc -b tsconfig.src.json && tsc-alias -p tsconfig.src.json",
    "start": "node dist/${SERVICE:-token}/index.js",
    "start:token": "node dist/token/index.js",
    "start:bank": "node dist/bank/index.js",
    "dev:token": "tsx watch src/token/index.ts",
    "dev:bank": "tsx watch src/bank/index.ts",
    "check": "tsc -b --noEmit && eslint . && prettier --check .",
    "fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "XRPL_NETWORK=devnet SIGNING_PROVIDER=sm vitest run --config vitest.integration.config.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@google-cloud/kms": "^5.5.0",
    "@google-cloud/pubsub": "^5.3.0",
    "@google-cloud/secret-manager": "^6.1.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "firebase-admin": "^13.9.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsqr": "^1.4.0",
    "multer": "^2.1.1",
    "pdf-to-img": "^6.0.0",
    "pngjs": "^7.0.0",
    "ripple-keypairs": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.7.0",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.17",
    "bip39": "^3.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14",
  "pnpm": {
    "overrides": {
      "vite": "^8.0.7",
      "http-proxy-agent": ">=7.0.0"
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@scarf/scarf",
      "esbuild",
      "protobufjs"
    ]
  }
}
