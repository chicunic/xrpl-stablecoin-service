{
  "name": "xrpl-stablecoin-service",
  "version": "0.1.0",
  "description": "XRPL stablecoin issuance platform - REST API backend on Google Cloud Run",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc -b tsconfig.src.json && tsc-alias -p tsconfig.src.json",
    "start": "node dist/${SERVICE:-token}/index.js",
    "start:token": "node dist/token/index.js",
    "start:bank": "node dist/bank/index.js",
    "dev:token": "tsx watch src/token/index.ts",
    "dev:bank": "tsx watch src/bank/index.ts",
    "check": "tsc -b --noEmit && eslint . && prettier --check .",
    "fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "XRPL_NETWORK=devnet SIGNING_PROVIDER=sm vitest run --config vitest.integration.config.ts",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "@google-cloud/kms": "^5.5.1",
    "@google-cloud/pubsub": "^5.3.1",
    "@google-cloud/secret-manager": "^6.1.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "firebase-admin": "^14.0.0",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "jsqr": "^1.4.0",
    "multer": "^2.2.0",
    "pdf-to-img": "^6.2.0",
    "pngjs": "^7.0.0",
    "ripple-keypairs": "^3.0.0",
    "swagger-ui-express": "^5.0.1",
    "xrpl": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.20",
    "bip39": "^3.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
