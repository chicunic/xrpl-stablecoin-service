# --- Token service ---

# XRPL network: localnet / devnet / testnet / mainnet
XRPL_NETWORK=testnet

# Signing provider: sm (Secret Manager) / kms (Google Cloud KMS)
SIGNING_PROVIDER=sm

# Wallet mnemonic (injected via Cloud Run --set-secrets in production)
MNEMONIC=

# Bank service URL (called by Token service)
BANK_SERVICE_URL=http://localhost:8080

# Bank auth token (injected via Cloud Run --set-secrets in production)
BANK_AUTH_TOKEN=

# MFA token secret (injected via Cloud Run --set-secrets in production)
MFA_TOKEN_SECRET=

# Token issuer KMS key path (Secret Manager path)
JPYN_KMS_KEY_PATH=projects/PROJECT/secrets/xrpl-issuer-seed/versions/latest

# JPYN MPToken issuance id (set after running setup-mpt-issuance)
JPYN_MPT_ISSUANCE_ID=

# JPYN permissioned domain id (set after running setup-domain)
JPYN_DOMAIN_ID=

# Bind the MPToken issuance to the permissioned domain (on-chain KYC enforcement).
# Requires the SingleAssetVault amendment (not enabled on mainnet as of 2026-06) — keep
# false until it activates; KYC is enforced at the application layer in the meantime.
MPT_ENABLE_DOMAIN_ID=false

# --- Bank service ---

# JWT secret (injected via Cloud Run --set-secrets in production)
BANK_JWT_SECRET=
