# GCP Project
GCP_PROJECT_ID=nexbridge-486208

# Firestore Emulator (comment out to use cloud Firestore)
FIRESTORE_EMULATOR_HOST=localhost:8081

# Pub/Sub Emulator (uncomment for local development)
# PUBSUB_EMULATOR_HOST=localhost:8085

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Token service
XRPL_URL=wss://s.altnet.rippletest.net:51233

# Wallet derivation (BIP44)
# Local dev: set MNEMONIC directly (takes priority over Secret Manager)
MNEMONIC=prefer post enrich hurdle bird absurd hill cruel device cause genuine picture
# Production: use Secret Manager path instead
MNEMONIC_SECRET_PATH=projects/PROJECT/secrets/xrpl-mnemonic/versions/latest

# Bank service integration
BANK_SERVICE_URL=http://localhost:8081
# BANK_AUTH_TOKEN is read from Secret Manager at runtime
# Override path: BANK_AUTH_TOKEN_SECRET_PATH (default: projects/nexbridge-486208/secrets/bank-auth-token/versions/latest)
# Generate token via: POST /api/v1/accounts/me/api-token (requires corporate account login)
CORPORATE_ACCOUNT_ID=

# Bank service
BANK_JWT_SECRET=your-secret-key-here
