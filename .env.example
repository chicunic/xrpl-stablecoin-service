# --- Token service ---

# XRPL network: devnet / testnet / mainnet
XRPL_NETWORK=testnet

# Signing provider: sm (Secret Manager) / kms (Google Cloud KMS)
SIGNING_PROVIDER=sm

# Wallet mnemonic (Secret Manager path)
MNEMONIC_SECRET_PATH=projects/PROJECT/secrets/xrpl-mnemonic/versions/latest

# Google OAuth2 client ID
GOOGLE_CLIENT_ID=

# Bank service URL (called by Token service)
BANK_SERVICE_URL=http://localhost:8080

# Bank auth token (Secret Manager path, used to call Bank service)
BANK_AUTH_TOKEN_SECRET_PATH=projects/PROJECT/secrets/bank-auth-token/versions/latest

# --- Bank service ---

# JWT secret (Secret Manager path)
BANK_JWT_SECRET_PATH=projects/PROJECT/secrets/bank-jwt-secret/versions/latest
